{
  "name": "openclaw-lifecoach",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw Life Coach package with manifest-driven installer and runtime self-test.",
  "type": "commonjs",
  "bin": {
    "openclaw-lifecoach": "scripts/install-openclaw.js"
  },
  "scripts": {
    "install:openclaw": "node scripts/install-openclaw.js",
    "selftest": "node scripts/run-local-selftest.js",
    "validate:package": "node scripts/validate-package.js",
    "console:dev": "node apps/console/server.js",
    "gateway:dev": "node apps/gateway/server.js",
    "platform:dev": "node apps/platform/server.js",
    "test:control-plane": "node tests/control-plane.e2e.js",
    "test:platform": "node tests/platform.e2e.js"
  },
  "engines": {
    "node": ">=18"
  }
}
