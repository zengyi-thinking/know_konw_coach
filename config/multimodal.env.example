# Multimodal switches
ENABLE_MULTIMODAL=true
ENABLE_VOICE_CHECKIN=true
ENABLE_VISION_REFLECTION=true

# Optional routing defaults
LIFECOACH_DEFAULT_INPUT_MODE=text
LIFECOACH_ENABLE_AUDIO_TRANSCRIBE=true
LIFECOACH_ENABLE_IMAGE_ANALYSIS=true

# Runtime expects real provider values from environment only.
# Do not commit real CREATION_AI_* values into the repository.
