  "properties": {
    "status": { "type": "string" },
    "practiceSignal": { "type": "string" },
    "followupMode": { "type": "string" },
    "continuityLinked": { "type": "boolean" },
    "actionReady": { "type": "boolean" },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
