{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["issues", "suggestions"],
  "properties": {
    "issues": { "type": "array", "items": { "type": "string" } },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue", "suggestion"],
        "properties": {
          "issue": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    }
  }
}
